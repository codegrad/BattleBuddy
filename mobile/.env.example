# Copy to .env.local and fill in values. Never commit .env.local.

# Supabase (safe to expose — RLS enforces row access)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend Edge Functions base URL (your Supabase project URL + /functions/v1)
EXPO_PUBLIC_API_URL=https://your-project.supabase.co/functions/v1
